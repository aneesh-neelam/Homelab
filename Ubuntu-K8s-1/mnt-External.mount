[Unit]
Description=VMware Shared Folder - External
After=systemd-modules-load.service
Requires=systemd-modules-load.service
Before=snap.k8s.kubelet.service

[Mount]
What=.host:/External
Where=/mnt/External
Type=fuse.vmhgfs-fuse
Options=allow_other,umask=000,defaults

[Install]
WantedBy=multi-user.target
